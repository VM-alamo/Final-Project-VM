<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Yuki Shop</title>
  <link rel="stylesheet" href="styles.css" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
</head>
<body>

  <!-- NAVBAR -->
  <header class="navbar">
    <div class="nav-left">
      <button class="pill">Shop Now!</button>
      <button class="pill">Best Sellers</button>
      <button class="pill">Join the Club!</button>
    </div>
    <div class="nav-right pill cart">
      🛒 3 items
    </div>
  </header>

  <!-- HERO -->
  <section class="hero">
    <h1 class="logo">YUKI</h1>
    <p class="subtitle">Welcome to the Yuki Shop!</p>
    <p class="tagline">The cutest merch for all kitty lovers!</p>
    <button class="primary">Shop Now ›</button>
  </section>

  <!-- FEATURE CONTAINER -->
  <section class="feature-box">

    <div class="feature left">
      <h3>Limited Edition Plush!</h3>
      <img src="yuki-plush.png" alt="Yuki Plush" />
      <p>Get your adorable Yuki Plush!</p>
      <button class="secondary">Grab Yours ›</button>
    </div>

    <div class="feature center">
      <span class="ribbon">Super Cute & Kawaii Style!</span>
      <img src="yuki-main.png" alt="Yuki mascot" />
      <button class="primary pink">Shop the Collection ›</button>
    </div>

    <div class="feature right">
      <p class="follow-title">Follow us for purr-fect updates!</p>
      <button class="secondary">Follow Us ›</button>

      <div class="links">
        <button class="pill small">Shop Accessories</button>
        <button class="pill small">Shop Stickers</button>
      </div>
    </div>

  </section>

  <!-- NEWSLETTER -->
  <section class="newsletter">
    <h3>Sign Up for Sweet Deals!</h3>
    <p>Join our mailing list for exclusive discounts!</p>
    <div class="signup">
      <input type="email" placeholder="Enter your email..." />
      <button class="primary">Subscribe</button>
    </div>
  </section>

</body>
</html>
